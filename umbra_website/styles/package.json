{
  "name": "umbra-website-css",
  "version": "0.0.1",
  "private": true,
  "description": "Tailwind CSS build for the Umbra website",
  "scripts": {
    "build": "tailwindcss -c tailwind.config.js -i input.css -o ../static/css/umbra.css --minify",
    "watch": "tailwindcss -c tailwind.config.js -i input.css -o ../static/css/umbra.css --watch",
    "screenshot": "node ../scripts/screenshot.js"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "playwright": "^1.45.0",
    "tailwindcss": "^3.4.0"
  }
}
