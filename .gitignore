# Cargo build artefacts (matches any depth, including crates/target/)
target/

# Generated by cargo when running `cargo build` on the workspace
**/*.rs.bk

# IDE / editor
.idea/
.vscode/
*.swp

# OS
.DS_Store

# Runtime SQLite databases produced by `cargo run -p umbral-cli` (the
# demo's file-backed pool, plus any tempfiles tests may leave behind).
*.db
*.db-journal
*.db-wal
*.db-shm

node_modules
create_db.sh

# Throwaway cot.rs comparison benchmark (not part of umbral; never committed).
examples/cot-bench/

# Git worktrees created by the using-git-worktrees skill
.worktrees/

# umbral-playground: the prebuilt frontend bundle (dist/) IS committed so it
# ships in the published crate; build.rs uses it when no Node toolchain is
# present. node_modules and the vite intermediate (frontend/dist/) are not.
plugins/umbral-playground/src/generated_assets.rs
plugins/umbral-playground/frontend/node_modules/
plugins/umbral-playground/frontend/dist/

.env

# Media storage (local FS + S3).
media/

# Local planning drafts (social / marketing copy — local-only, never committed)
/planning/social/

shadow-security.md

# Superpowers brainstorm session state (local, ephemeral)
.superpowers/
slides
info
