# Cargo build artefacts (matches any depth, including crates/target/)
target/

# Generated by cargo when running `cargo build` on the workspace
**/*.rs.bk

# IDE / editor
.idea/
.vscode/
*.swp

# OS
.DS_Store

# Runtime SQLite databases produced by `cargo run -p umbra-cli` (the
# demo's file-backed pool, plus any tempfiles tests may leave behind).
*.db
*.db-journal
*.db-wal
*.db-shm

node_modules
create_db.sh

# Throwaway cot.rs comparison benchmark (not part of umbra; never committed).
examples/cot-bench/

# Git worktrees created by the using-git-worktrees skill
.worktrees/

# umbra-playground build artifacts
plugins/umbra-playground/dist/
plugins/umbra-playground/src/generated_assets.rs
plugins/umbra-playground/frontend/node_modules/

.env

# Media storage (local FS + S3).
media/

# Local planning drafts
/planning/github-sponsors-profile.md

shadow-security.md
