{
  "$schema": "https://raw.githubusercontent.com/SpecraDocs/specra-sdk/main/config/specra.config.schema.json",
  "site": {
    "title": "Umbral",
    "description": "Batteries-included Rust web framework: ORM, managed migrations, REST API, admin, auth, sessions, tasks, email. Built on axum + sqlx.",
    "url": "https://dalmasonto.github.io/umbral",
    "baseUrl": "/",
    "language": "en",
    "organizationName": "umbral",
    "projectName": "umbral",
    "activeVersion": "v0.0.1",
    "defaultProduct": {
      "label": "Docs",
      "icon": "book-open"
    }
  },
  "deployment": {
    "target": "github-pages",
    "basePath": "umbral",
    "customDomain": false
  },
  "theme": {
    "defaultMode": "dark",
    "respectPrefersColorScheme": true
  },
  "navigation": {
    "showSidebar": true,
    "collapsibleSidebar": false,
    "showBreadcrumbs": true,
    "showTableOfContents": true,
    "tocPosition": "right",
    "tocMaxDepth": 3
  },
  "social": {
    "github": "https://github.com/dalmasonto/umbral"
  },
  "search": {
    "enabled": false
  },
  "footer": {
    "copyright": "Copyright © 2026 Umbral. MIT licensed.",
    "links": [
      {
        "title": "Documentation",
        "items": [
          {
            "label": "What is Umbral?",
            "href": "/docs/v0.0.1/about"
          }
        ]
      },
      {
        "title": "Community",
        "items": [
          {
            "label": "GitHub",
            "href": "https://github.com/dalmasonto/umbral"
          }
        ]
      }
    ]
  },
  "features": {
    "editUrl": "https://github.com/dalmasonto/umbral/edit/main/documentation/docs",
    "showLastUpdated": true,
    "showReadingTime": true,
    "showAuthors": false,
    "showTags": true,
    "versioning": true,
    "i18n": false
  }
}
